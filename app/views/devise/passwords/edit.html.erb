  

  

<div class="d-flex justify-content-center align-items-center min-vh-100 bg-light">
  <div class="container" style="max-width: 500px;">
    <div class="card">
      <div class="card-body p-5">
        <h2 class="mb-4 text-center">Change your password</h2>
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "needs-validation", novalidate: true, data: { controller: "password-validation" } }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>
          <%= f.hidden_field :reset_password_token %>

          <!-- New Password Field -->
          <div class="mb-3">
            <%= f.label :password, "New password", class: "form-label" %>
            <div class="input-group">
              <%= f.password_field :password, id: "password", autofocus: true, autocomplete: "new-password", class: "form-control border-end-0", required: true, data: { password_validation_target: "password", action: "input->password-validation#validatePassword" } %>
              <span class="input-group-text">
                <i class="fa-solid fa-eye toggle-password-icon" id="togglePasswordIcon" style="cursor: pointer;"></i>
              </span>
            </div>
            
            <div class="mt-2">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="fw-bold">Password Strength:</small>
                <small data-password-validation-target="meterText" class="fw-bold text-muted"></small>
              </div>
              <div class="progress" style="height: 5px;">
                <div class="progress-bar bg-danger" role="progressbar" style="width: 0%;" data-password-validation-target="meter"></div>
              </div>
            </div>

            <div class="mt-2" style="font-size: 0.85rem;">
              <div data-password-validation-target="lengthCheck" data-text="Minimum 12 characters" class="text-muted mb-1">○ Minimum 12 characters</div>
              <div data-password-validation-target="uppercaseCheck" data-text="Contains uppercase letter" class="text-muted mb-1">○ Contains uppercase letter</div>
              <div data-password-validation-target="lowercaseCheck" data-text="Contains lowercase letter" class="text-muted mb-1">○ Contains lowercase letter</div>
              <div data-password-validation-target="numberCheck" data-text="Contains number" class="text-muted mb-1">○ Contains number</div>
              <div data-password-validation-target="specialCheck" data-text="Contains special character" class="text-muted mb-1">○ Contains special character</div>
            </div>
          </div>

          <!-- Confirm Password Field -->
          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
            <div class="input-group">
              <%= f.password_field :password_confirmation, id: "confirmPassword", autocomplete: "new-password", class: "form-control border-end-0", required: true, data: { password_validation_target: "confirmation", action: "input->password-validation#validateConfirmation" } %>
              <span class="input-group-text">
                <i class="fa-solid fa-eye toggle-password-icon" id="toggleConfirmPasswordIcon" style="cursor: pointer;"></i>
              </span>
            </div>
            <div data-password-validation-target="matchError" class="invalid-feedback"></div>
          </div>

          <div class="d-grid">
            <%= f.submit "Change my password", class: "btn btn-primary btn-md" %>
          </div>
        <% end %>

        <div class="mt-3 text-center">
          <%= render "devise/shared/links" %>
        </div>
    </div>
  </div>
</div>
