<% 
  company_name = current_user.company&.name
  full_title = company_name.present? ? "#{company_name} Tax Submissions" : "Tax Submissions"
  display_company = company_name.present? ? truncate(company_name, length: 30) : nil
  display_title = display_company ? "#{display_company} Tax Submissions" : "Tax Submissions"
%>
<% content_for :page_title, full_title %>
<%= javascript_include_tag "client_submissions", "data-turbo-track": "reload", type: "module" %>

<div class="container py-2 py-md-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0" title="<%= company_name %>"><%= display_title %></h2>
    <div class="d-flex gap-2">
      <% if current_user.company_id.present? %>
        <%= link_to "Incoming Submissions", tax_submissions_path, class: "btn btn-outline-primary btn-sm" %>
      <% end %>
      <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#submitDocsModal">
        Submit Documents
      </button>
    </div>
  </div>

  <ul class="custom_nav_tabs nav nav-tabs mb-3" id="submissionTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="unarchived-tab" data-bs-toggle="tab" data-bs-target="#unarchived" type="button" role="tab" aria-controls="unarchived" aria-selected="true">
        Active Submissions
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="archived-tab" data-bs-toggle="tab" data-bs-target="#archived" type="button" role="tab" aria-controls="archived" aria-selected="false">
        Archived Submissions
      </button>
    </li>
  </ul>

  <div class="tab-content">
    <div class="tab-pane fade show active" id="unarchived">
      <%= render partial: 'submission_table', locals: { submissions: @unarchived_submissions, archived_table: false } %>
    </div>
    <div class="tab-pane fade" id="archived">
      <%= render partial: 'submission_table', locals: { submissions: @archived_submissions, archived_table: true } %>
    </div>
  </div>
</div>

<!-- Submit Documents Modal -->
<div class="modal fade" id="submitDocsModal" tabindex="-1" aria-labelledby="submitDocsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content shadow-md border-0 rounded-4">
      
      <div class="modal-header border-0">
        <h4 class="modal-title fw-bold" id="submitDocsModalLabel">Submit Tax Documents</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body p-4 pt-0">
        <%= form_with model: @tax_submission, url: tax_submissions_path, local: true, html: { multipart: true } do |f| %>
          <% if @tax_submission.errors.any? %>
            <div class="alert alert-danger py-2 small mb-3">
              <ul class="mb-0">
                <% @tax_submission.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
            <input type="hidden" id="has_submission_errors" value="true">
          <% end %>
          <div class="row g-3">

            <div class="col-12">
              <%= f.label :company_id, "Company Name", class: "form-label fw-semibold small text-muted" %>
              <%= f.collection_select :company_id, @companies || [], :id, :name, { prompt: "Select Company" }, { class: "form-select rounded-3", id: "company_select", required: true } %>
            </div>

            <div class="col-12">
              <%= f.label :invoice_id, "Invoice Number", class: "form-label fw-semibold small text-muted" %>
              <%= f.select :invoice_id, [], { prompt: "Select Invoice" }, { class: "form-select rounded-3", id: "invoice_select", required: true } %>
              <small class="form-text text-muted">Please select a company first to load available invoices.</small>
            </div>

            <div class="col-12">
              <%= f.label :form_2307, "Form 2307", class: "form-label fw-semibold small text-muted" %>
              <%= f.file_field :form_2307,
                    class: "form-control rounded-3",
                    required: true,
                    accept: "image/*,application/pdf",
                    id: "form_2307_input" %>
              <small class="form-text text-muted">Only images (JPG, PNG) and PDFs are allowed.</small>
              <ul id="form_2307_list" class="list-group mt-2"></ul>
            </div>

            <div class="col-12">
              <%= f.label :deposit_slip, "Deposit Slip or Bank Transfer Details", class: "form-label fw-semibold small text-muted" %>
              <%= f.file_field :deposit_slip,
                    multiple: true,
                    class: "form-control rounded-3",
                    required: true,
                    accept: "image/*,application/pdf",
                    id: "deposit_slip_input" %>
              <small class="form-text text-muted">You can upload multiple images or PDFs.</small>
              <ul id="deposit_slip_list" class="list-group mt-2"></ul>
            </div>

            <div class="col-12">
              <%= f.label :details, "Additional Notes", class: "form-label fw-semibold small text-muted" %>
              <%= f.text_area :details, class: "form-control rounded-3", rows: 4 %>
            </div>

          </div>

          <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" class="btn btn-back px-4" data-bs-dismiss="modal">Cancel</button>
            <%= f.submit "Submit", class: "btn btn-primary px-4" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= render "tax_submissions/shared/modal" %>