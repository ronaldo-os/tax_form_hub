<div class="modal fade" id="midCycleModal-<%= invoice.id %>" tabindex="-1" aria-labelledby="midCycleModalLabel-<%= invoice.id %>" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-semibold" id="midCycleModalLabel-<%= invoice.id %>">Add Mid-cycle Subscription</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="#" method="post">
          <div class="mb-3">
            <label for="itemName-<%= invoice.id %>" class="form-label fw-medium">Service / Item Name</label>
            <input type="text" class="form-control" id="itemName-<%= invoice.id %>" placeholder="e.g. Extra user license" required>
          </div>
          
          <div class="row mb-3">
            <div class="col-md-6">
              <label for="quantity-<%= invoice.id %>" class="form-label fw-medium">Quantity</label>
              <input type="number" class="form-control" id="quantity-<%= invoice.id %>" value="1" min="1" required>
            </div>
            <div class="col-md-6">
              <label for="price-<%= invoice.id %>" class="form-label fw-medium">Unit Price</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" class="form-control" id="price-<%= invoice.id %>" placeholder="0.00" step="0.01" required>
              </div>
            </div>
          </div>
          
          <div class="mb-3">
            <label for="effectiveDate-<%= invoice.id %>" class="form-label fw-medium">Effective Date</label>
            <input type="date" class="form-control" id="effectiveDate-<%= invoice.id %>" value="<%= Date.current %>" required>
          </div>
          
          <div class="mb-3">
            <label class="form-label d-block fw-medium">Proration Handling</label>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="proration-<%= invoice.id %>" id="prorate-<%= invoice.id %>" value="prorate" checked>
              <label class="form-check-label" for="prorate-<%= invoice.id %>">
                <strong>Prorate:</strong> Charge for remaining days in cycle
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="proration-<%= invoice.id %>" id="full-<%= invoice.id %>" value="full">
              <label class="form-check-label" for="full-<%= invoice.id %>">
                <strong>Full Amount:</strong> Charge the full cycle amount
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="proration-<%= invoice.id %>" id="next-<%= invoice.id %>" value="next">
              <label class="form-check-label" for="next-<%= invoice.id %>">
                <strong>Do Not Charge Now:</strong> Bill next regular cycle
              </label>
            </div>
          </div>
          
          <div class="mb-3">
            <label class="form-label d-block fw-medium">Charge Type</label>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="chargeType-<%= invoice.id %>" id="recurring-<%= invoice.id %>" value="recurring" checked>
              <label class="form-check-label" for="recurring-<%= invoice.id %>">Recurring</label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="chargeType-<%= invoice.id %>" id="onetime-<%= invoice.id %>" value="onetime">
              <label class="form-check-label" for="onetime-<%= invoice.id %>">One-Time</label>
            </div>
          </div>
          
          <div class="mb-3">
            <label for="memo-<%= invoice.id %>" class="form-label fw-medium">Description / Memo</label>
            <textarea class="form-control" id="memo-<%= invoice.id %>" rows="2" placeholder="Optional notes..."></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-back" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary">Add Mid-cycle Subscription</button>
      </div>
    </div>
  </div>
</div>
