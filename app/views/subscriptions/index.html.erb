<% content_for :page_title, "Subscriptions" %>

<div class="container py-2 py-md-5">

  <div class="mb-3">
    <h4>Subscriptions</h4>
  </div>

  <div class="d-flex align-items-center mb-3">
    <!-- Tab Navigation -->
    <ul class="custom_nav_tabs nav nav-tabs border-0" id="subscriptionTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active fw-semibold" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab" aria-controls="active" aria-selected="true">
          Active Subscriptions
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link fw-semibold" id="finished-tab" data-bs-toggle="tab" data-bs-target="#finished" type="button" role="tab" aria-controls="finished" aria-selected="false">
          Finished Subscriptions
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link fw-semibold" id="cancelled-tab" data-bs-toggle="tab" data-bs-target="#cancelled" type="button" role="tab" aria-controls="cancelled" aria-selected="false">
          Cancelled Subscriptions
        </button>
      </li>
    </ul>
  </div>

  <div class="tab-content" id="subscriptionTabsContent">
    <div class="tab-pane fade show active" id="active" role="tabpanel" aria-labelledby="active-tab">
      <div class="card mb-4">
        <div class="card-body p-3">
          <h5>Active Subscriptions</h5>
          <%= render "subscriptions_table", subscriptions: @active_subscriptions %>
        </div>
      </div>
    </div>
    
    <div class="tab-pane fade" id="finished" role="tabpanel" aria-labelledby="finished-tab">
      <div class="card mb-4">
        <div class="card-body p-3">
          <h5>Finished Subscriptions</h5>
          <%= render "subscriptions_table", subscriptions: @finished_subscriptions %>
        </div>
      </div>
    </div>
    
    <div class="tab-pane fade" id="cancelled" role="tabpanel" aria-labelledby="cancelled-tab">
      <div class="card">
        <div class="card-body p-3">
          <h5>Cancelled Subscriptions</h5>
          <%= render "subscriptions_table", subscriptions: @cancelled_subscriptions %>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-5 mb-3">
    <h4>Price Adjustments</h4>
  </div>

  <div class="d-flex align-items-center mb-3">
    <!-- Tab Navigation for Price Adjustments -->
    <ul class="custom_nav_tabs nav nav-tabs border-0" id="priceAdjustmentTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active fw-semibold" id="active-pa-tab" data-bs-toggle="tab" data-bs-target="#active-pa" type="button" role="tab" aria-controls="active-pa" aria-selected="true">
          Active Adjustments
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link fw-semibold" id="finished-pa-tab" data-bs-toggle="tab" data-bs-target="#finished-pa" type="button" role="tab" aria-controls="finished-pa" aria-selected="false">
          Finished Adjustments
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link fw-semibold" id="cancelled-pa-tab" data-bs-toggle="tab" data-bs-target="#cancelled-pa" type="button" role="tab" aria-controls="cancelled-pa" aria-selected="false">
          Cancelled Adjustments
        </button>
      </li>
    </ul>
  </div>

  <div class="tab-content" id="priceAdjustmentTabsContent">
    <div class="tab-pane fade show active" id="active-pa" role="tabpanel" aria-labelledby="active-pa-tab">
      <div class="card mb-4">
        <div class="card-body p-3">
          <h5>Active Adjustments</h5>
          <%= render "price_adjustments_table", subscriptions: @active_price_adjustments %>
        </div>
      </div>
    </div>
    
    <div class="tab-pane fade" id="finished-pa" role="tabpanel" aria-labelledby="finished-pa-tab">
      <div class="card mb-4">
        <div class="card-body p-3">
          <h5>Finished Adjustments</h5>
          <%= render "price_adjustments_table", subscriptions: @finished_price_adjustments %>
        </div>
      </div>
    </div>
    
    <div class="tab-pane fade" id="cancelled-pa" role="tabpanel" aria-labelledby="cancelled-pa-tab">
      <div class="card">
        <div class="card-body p-3">
          <h5>Cancelled Adjustments</h5>
          <%= render "price_adjustments_table", subscriptions: @cancelled_price_adjustments %>
        </div>
      </div>
    </div>
  </div>
</div>
