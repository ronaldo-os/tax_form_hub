<div class="table-responsive overflow-visible">
    <table class="table table-hover align-middle mb-0 subscription-table w-100">
      <thead class="table-light">
        <tr>
          <th class="ps-4">Recipient</th>
          <th>Description</th>
          <th>Billing Cycle</th>
          <th>Status</th>
          <th>Next Invoice</th>
          <th class="text-end">Amount</th>
          <th class="pe-4 text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% subscriptions.each do |wrapper| %>
          <% invoice = wrapper.invoice %>
          <% item = wrapper.item %>
          <% item_index = wrapper.index %>
          <% cycle = invoice.extract_subscription_field(item, 'billing_cycle') || 'monthly' %>
          <% start_date_str = invoice.extract_subscription_field(item, 'start_date') %>
          
          <tr>
            <td class="ps-4 fw-medium">
              <%= link_to invoice.recipient_company&.name || "Unknown Company", subscription_path(invoice, item_index: item_index), class: "text-decoration-none" %>
            </td>
            <td>
              <span class="text-truncate d-inline-block" style="max-width: 200px;">
                <%= item['description'].presence || "Subscription Service" %>
              </span>
            </td>
            <td>
              <span class="badge bg-secondary">
                <i class="fa-solid fa-clock-rotate-left me-1"></i>
                <%= cycle.capitalize %>
              </span>
            </td>
            <td>
              <% if wrapper.subscription_active? %>
                <span class="badge bg-success">Active</span>
              <% elsif wrapper.subscription_cancelled? %>
                <span class="badge bg-danger">Cancelled</span>
              <% else %>
                <span class="badge bg-secondary">Finished</span>
              <% end %>
            </td>
            <td>
              <% if wrapper.subscription_active? && start_date_str.present? %>
                <% 
                  start_d = Date.parse(start_date_str) rescue nil
                  if start_d
                    current_sequence = invoice.recurring_sub_invoices.count + 1
                    next_date = start_d
                    current_sequence.times { next_date = invoice.calculate_next_period_date(next_date, cycle) }
                    
                    days_left = (next_date - Date.current).to_i
                    text_class = days_left <= 7 ? "text-danger fw-bold" : "text-muted"
                %>
                <div class="<%= text_class %>">
                  <%= next_date.strftime("%b %d, %Y") %>
                  <small class="d-block">
                    <% if days_left < 0 %>
                      Overdue by <%= days_left.abs %> days
                    <% elsif days_left == 0 %>
                      Today
                    <% else %>
                      In <%= days_left %> days
                    <% end %>
                  </small>
                </div>
                <% end %>
              <% else %>
                <span class="text-muted">-</span>
              <% end %>
            </td>
            <td class="text-end fw-semibold">
              <%= number_to_currency(wrapper.total_amount, unit: invoice.currency + ' ') %>
            </td>
            <td class="pe-4 text-end">
              <div class="dropdown text-center">
                <button class="btn btn-link text-muted p-0 text-decoration-none fs-3" type="button" id="actionsDropdown_<%= invoice.id %>_<%= item_index %>" data-bs-toggle="dropdown" aria-expanded="false">⋮</button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="actionsDropdown_<%= invoice.id %>_<%= item_index %>">
                  <li>
                    <%= link_to "View Details", subscription_path(invoice, item_index: item_index), class: "dropdown-item" %>
                  </li>
                  <% if wrapper.subscription_active? %>
                    <li>
                      <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#midCycleModal-<%= invoice.id %>-<%= item_index %>">
                        Add Mid-cycle Subscription
                      </button>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#cancelSubscriptionModal-<%= invoice.id %>-<%= item_index %>">
                        Cancel Subscription
                      </button>
                    </li>
                  <% end %>
                  <% if wrapper.subscription_cancelled? %>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#cancelledDetailsModal-<%= invoice.id %>-<%= item_index %>">
                        View Cancellation Details
                      </button>
                    </li>
                  <% end %>
                </ul>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% subscriptions.each do |wrapper| %>
    <% invoice = wrapper.invoice %>
    <% item_index = wrapper.index %>
    <%= render "mid_cycle_modal", invoice: invoice, item_index: item_index %>
    <% if wrapper.subscription_active? %>
      <%= render "cancel_subscription_modal", subscription: invoice, item_index: item_index %>
    <% end %>
    <% if wrapper.subscription_cancelled? && invoice.cancellation_line_item %>
      <% 
        cancel_item = {
          index: invoice.id.to_s + "-" + item_index.to_s,
          is_cancellation: true,
          item: invoice.cancellation_line_item,
          description: invoice.cancellation_line_item['description']
        }
      %>
      <%= render "cancelled_details_modal", item: cancel_item %>
    <% end %>
  <% end %>
