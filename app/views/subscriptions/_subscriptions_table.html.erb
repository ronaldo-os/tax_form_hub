<div class="table-responsive overflow-visible">
    <table class="table table-hover align-middle mb-0 subscription-table w-100">
      <thead class="table-light">
        <tr>
          <th class="ps-4">Recipient</th>
          <th>Description</th>
          <th>Billing Cycle</th>
          <th>Status</th>
          <th>Next Invoice</th>
          <th class="text-end">Amount</th>
          <th class="pe-4 text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% subscriptions.each do |invoice| %>
          <% primary_item = invoice.primary_recurring_item || {} %>
          <tr>
            <td class="ps-4 fw-medium">
              <%= link_to invoice.recipient_company&.name || "Unknown Company", subscription_path(invoice), class: "text-decoration-none" %>
            </td>
            <td>
              <span class="text-truncate d-inline-block" style="max-width: 200px;">
                <%= invoice.message.presence || "Subscription Service" %>
              </span>
            </td>
            <td>
              <span class="badge bg-secondary">
                <i class="fa-solid fa-clock-rotate-left me-1"></i>
                <%= (primary_item[:cycle] || 'monthly').capitalize %>
              </span>
            </td>
            <td>
              <% is_active = invoice.subscription_active? %>
              <span class="badge <%= is_active ? 'bg-success' : 'bg-secondary' %>">
                <%= is_active ? 'Active' : 'Finished' %>
              </span>
            </td>
            <td>
              <% if is_active && primary_item[:start_date] %>
                <% 
                  start_d = Date.parse(primary_item[:start_date]) rescue nil
                  if start_d
                    current_sequence = invoice.recurring_sub_invoices.count + 1
                    next_date = start_d
                    cycle = primary_item[:cycle] || 'monthly'
                    current_sequence.times { next_date = invoice.calculate_next_period_date(next_date, cycle) }
                    
                    days_left = (next_date - Date.current).to_i
                    text_class = days_left <= 7 ? "text-danger fw-bold" : "text-muted"
                %>
                <div class="<%= text_class %>">
                  <%= next_date.strftime("%b %d, %Y") %>
                  <small class="d-block">
                    <% if days_left < 0 %>
                      Overdue by <%= days_left.abs %> days
                    <% elsif days_left == 0 %>
                      Today
                    <% else %>
                      In <%= days_left %> days
                    <% end %>
                  </small>
                </div>
                <% end %>
              <% else %>
                <span class="text-muted">-</span>
              <% end %>
            </td>
            <td class="text-end fw-semibold">
              <%= number_to_currency(invoice.grand_total, unit: invoice.currency + ' ') %>
            </td>
            <td class="pe-4 text-end">
              <div class="dropdown text-center">
                <button class="btn btn-link text-muted p-0 text-decoration-none fs-3" type="button" id="actionsDropdown_<%= invoice.id %>" data-bs-toggle="dropdown" aria-expanded="false">⋮</button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="actionsDropdown_<%= invoice.id %>">
                  <li>
                    <%= link_to "View Details", subscription_path(invoice), class: "dropdown-item" %>
                  </li>
                  <li>
                    <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#midCycleModal-<%= invoice.id %>">
                      Add Mid-cycle Subscription
                    </button>
                  </li>
                  <% if is_active %>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <%= link_to "Cancel Subscription", cancel_subscription_path(invoice), data: { turbo_method: :patch, turbo_confirm: "Are you sure you want to cancel this subscription? This will stop all future recurring invoices." }, class: "dropdown-item text-danger" %>
                    </li>
                  <% end %>
                </ul>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% subscriptions.each do |invoice| %>
    <%= render "mid_cycle_modal", invoice: invoice %>
  <% end %>
