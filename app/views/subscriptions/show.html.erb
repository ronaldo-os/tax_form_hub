<div class="container mt-5">
  <div class="d-flex justify-content-between mt-5 mb-3">
    <div>
      <%= link_to "Back", subscriptions_path, class: "btn btn-back btn-md" %>
    </div>
  </div>

  <% primary_item = @subscription.primary_recurring_item || {} %>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4">
          <h5 class="mb-0 fw-bold">Subscription Overview</h5>
          <p class="text-muted mt-2 mb-0">For <%= @subscription.recipient_company&.name || "Unknown Company" %></p>
        </div>
        <div class="card-body px-4 py-4">
          <div class="row g-4">
            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Status</div>
              <% is_active = @subscription.subscription_active? %>
              <span class="badge <%= is_active ? 'bg-success' : 'bg-secondary' %> fs-6 px-3 py-2">
                <%= is_active ? 'Active' : 'Finished' %>
              </span>
            </div>
            
            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Billing Cycle</div>
              <div class="fs-5 fw-medium"><%= (primary_item[:cycle] || 'monthly').capitalize %></div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Amount</div>
              <div class="fs-5 fw-medium text-primary">
                <%= number_to_currency(@subscription.grand_total, unit: @subscription.currency + ' ') %>
                <small class="text-muted fs-6">/ <%= primary_item[:cycle] || 'monthly' %></small>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Start Date</div>
              <div class="fs-5 fw-medium">
                <%= primary_item[:start_date] ? Date.parse(primary_item[:start_date]).strftime("%B %d, %Y") : "N/A" %>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">End Date</div>
              <div class="fs-5 fw-medium">
                <%= primary_item[:end_date] ? Date.parse(primary_item[:end_date]).strftime("%B %d, %Y") : "Indefinite" %>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Next Invoice</div>
              <div class="fs-5 fw-medium">
                <% if is_active && @upcoming_invoice_date %>
                  <%= @upcoming_invoice_date.strftime("%B %d, %Y") %>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </div>
            </div>
            
            <div class="col-12">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Description</div>
              <div class="p-3 border rounded-3">
                <%= @subscription.message.presence || "No description provided." %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4">
          <h5 class="mb-0 fw-bold">
            <i class="fa-solid fa-code-merge me-2 text-primary"></i> Mid-Cycle Overview
          </h5>
          <p class="text-muted mt-2 mb-0">Track upcoming and recently generated mid-cycle subscription changes for this invoice.</p>
        </div>
        <div class="card-body p-0">
          <div class="row g-0">
            <div class="col-md-6 border-end">
              <div class="p-4">
                <h6 class="text-muted fw-semibold mb-3">Pending / Not Yet Generated</h6>
                <% if @mid_cycle_pending_items.empty? %>
                  <div class="text-center py-4">
                    <i class="fa-regular fa-clock fa-2x text-muted opacity-50 mb-2"></i>
                    <p class="text-muted small mb-0">No pending mid-cycle items.</p>
                  </div>
                <% else %>
                  <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                      <thead class="table-light text-muted">
                        <tr>
                          <th>Item Description</th>
                          <th>Generation Date</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% @mid_cycle_pending_items.each do |data| %>
                          <tr>
                            <td class="text-truncate" style="max-width: 150px;" title="<%= data[:item]['description'] %>">
                              <small><%= data[:item]['description'] %></small>
                            </td>
                            <td>
                              <span class="badge bg-info-subtle text-info fw-semibold border border-info-subtle">
                                <%= data[:expected_generation_date].strftime("%b %d, %Y") %>
                              </span>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                <% end %>
              </div>
            </div>
            <div class="col-md-6">
              <div class="p-4">
                <h6 class="text-muted fw-semibold mb-3">Generated Mid-Cycle Invoices</h6>
                <% if @generated_mid_cycle_invoices.empty? %>
                  <div class="text-center py-4">
                    <i class="fa-solid fa-file-invoice fa-2x text-muted opacity-50 mb-2"></i>
                    <p class="text-muted small mb-0">No mid-cycle invoices generated yet.</p>
                  </div>
                <% else %>
                  <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                      <thead class="table-light text-muted">
                        <tr>
                          <th>Invoice #</th>
                          <th>Date</th>
                          <th class="text-end">Amount</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% @generated_mid_cycle_invoices.each do |invoice| %>
                          <tr>
                            <td>
                              <%= link_to invoice.invoice_number, invoice_path(invoice), class: "text-decoration-none fw-medium", target: "_blank" %>
                            </td>
                            <td><small class="text-muted"><%= invoice.issue_date.strftime("%b %d, %Y") %></small></td>
                            <td class="text-end fw-semibold">
                              <%= number_to_currency(invoice.grand_total, unit: invoice.currency + ' ') %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">Generated Invoices</h5>
        </div>
        <div class="card-body p-0">
          <% if @invoices.empty? %>
            <div class="p-5 text-center text-muted">
              <i class="fa-solid fa-file-invoice fa-3x mb-3 opacity-50"></i>
              <p class="mb-0 fs-5">No sub-invoices generated yet.</p>
            </div>
          <% else %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="ps-4">Invoice #</th>
                    <th>Issue Date</th>
                    <th>Status</th>
                    <th class="text-end">Amount</th>
                    <th class="pe-4 text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% @invoices.each do |invoice| %>
                    <tr>
                      <td class="ps-4 fw-medium">
                        <%= link_to invoice.invoice_number, invoice_path(invoice), class: "text-decoration-none", target: "_blank" %>
                      </td>
                      <td><%= invoice.issue_date&.strftime("%b %d, %Y") %></td>
                      <td>
                        <% status_class = case invoice.status
                           when 'paid' then 'bg-success'
                           when 'draft' then 'bg-secondary'
                           when 'approved' then 'bg-primary'
                           when 'sent' then 'bg-info'
                           when 'overdue' then 'bg-danger'
                           else 'bg-secondary'
                           end %>
                        <span class="badge <%= status_class %>"><%= invoice.status.capitalize %></span>
                      </td>
                      <td class="text-end fw-semibold">
                        <%= number_to_currency(invoice.grand_total, unit: invoice.currency + ' ') %>
                      </td>
                      <td class="pe-4 text-end">
                        <%= link_to "View", invoice_path(invoice), class: "btn btn-sm btn-outline-secondary", target: "_blank" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4 mt-4 mt-lg-0">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4">
          <h5 class="mb-0 fw-bold">Contract Details</h5>
        </div>
        <div class="card-body px-4 py-4">
          <ul class="list-unstyled mb-0">
            <li class="d-flex justify-content-between mb-3">
              <span class="text-muted">Original Invoice #</span>
              <span class="fw-medium">
                <%= link_to @subscription.invoice_number, invoice_path(@subscription) %>
              </span>
            </li>
            <li class="d-flex justify-content-between mb-3">
              <span class="text-muted">Total Cycles Created</span>
              <span class="fw-medium"><%= @subscription.recurring_sub_invoices.count %></span>
            </li>
            <li class="d-flex justify-content-between mb-3">
              <span class="text-muted">Contract Created On</span>
              <span class="fw-medium"><%= @subscription.created_at.strftime("%b %d, %Y") %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
