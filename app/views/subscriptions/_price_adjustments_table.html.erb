<div class="table-responsive overflow-visible">
    <table class="table table-hover align-middle mb-0 subscription-table w-100">
      <thead class="table-light">
        <tr>
          <th class="ps-4">Recipient</th>
          <th>Description</th>
          <th>Type</th>
          <th>Billing Cycle</th>
          <th>Status</th>
          <th>Next Invoice</th>
          <th class="text-end pe-4">Adjustment Amount</th>
        </tr>
      </thead>
      <tbody>
        <% subscriptions.each do |invoice| %>
          <% 
            adj = invoice.recurring_price_adjustments.first || {}
            cycle = case adj['frequency']
                    when 'annually', 'yearly' then 'annual'
                    else 'monthly'
                    end
            start_date = adj['charge_start_date']
            description = adj['description_edit'].presence || adj['description'].presence || "Price Adjustment"
            type_label = (adj['type'] || adj['unit'] || 'Adjustment').capitalize
            
            amount_val = adj['amount'].to_f
            unit_val = adj['unit'] == '%' ? '%' : (invoice.currency + ' ')
            amount_display = adj['unit'] == '%' ? "#{amount_val}%" : number_to_currency(amount_val, unit: unit_val)
          %>
          <tr>
            <td class="ps-4 fw-medium">
              <%= link_to invoice.recipient_company&.name || "Unknown Company", price_adjustment_path(invoice), class: "text-decoration-none" %>
            </td>
            <td>
              <span class="text-truncate d-inline-block" style="max-width: 200px;">
                <%= description %>
              </span>
            </td>
            <td>
              <span class="badge bg-info text-dark">
                <%= type_label %>
              </span>
            </td>
            <td>
              <span class="badge bg-secondary">
                <i class="fa-solid fa-clock-rotate-left me-1"></i>
                <%= cycle.capitalize %>
              </span>
            </td>
            <td>
              <% if invoice.subscription_active? %>
                <span class="badge bg-success">Active</span>
              <% elsif invoice.subscription_cancelled? %>
                <span class="badge bg-danger">Cancelled</span>
              <% else %>
                <span class="badge bg-secondary">Finished</span>
              <% end %>
            </td>
            <td>
              <% if invoice.subscription_active? && start_date.present? %>
                <% 
                  start_d = Date.parse(start_date) rescue nil
                  if start_d
                    current_sequence = invoice.recurring_sub_invoices.count + 1
                    next_date = start_d
                    current_sequence.times { next_date = invoice.calculate_next_period_date(next_date, cycle) }
                    
                    days_left = (next_date - Date.current).to_i
                    text_class = days_left <= 7 ? "text-danger fw-bold" : "text-muted"
                %>
                <div class="<%= text_class %>">
                  <%= next_date.strftime("%b %d, %Y") %>
                  <small class="d-block">
                    <% if days_left < 0 %>
                      Overdue by <%= days_left.abs %> days
                    <% elsif days_left == 0 %>
                      Today
                    <% else %>
                      In <%= days_left %> days
                    <% end %>
                  </small>
                </div>
                <% end %>
              <% else %>
                <span class="text-muted">-</span>
              <% end %>
            </td>
            <td class="text-end fw-semibold pe-4">
              <%= amount_display %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% subscriptions.each do |invoice| %>
    <% if invoice.subscription_active? %>
      <%= render "cancel_subscription_modal", subscription: invoice %>
    <% end %>
    <% if invoice.subscription_cancelled? && invoice.cancellation_line_item %>
      <% 
        cancel_item = {
          index: invoice.id,
          is_cancellation: true,
          item: invoice.cancellation_line_item,
          description: invoice.cancellation_line_item['description']
        }
      %>
      <%= render "cancelled_details_modal", item: cancel_item %>
    <% end %>
  <% end %>
