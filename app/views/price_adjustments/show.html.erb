<div class="container mt-5">
  <div class="d-flex justify-content-between mt-5 mb-3">
    <div>
      <%= link_to "Back", subscriptions_path, class: "btn btn-back btn-md" %>
    </div>
  </div>

  <% 
    description = @adj['description_edit'].presence || @adj['description'].presence || "Price Adjustment"
    type_label = (@adj['type'] || @adj['unit'] || 'Adjustment').capitalize
    amount_val = @adj['amount'].to_f
    unit_val = @adj['unit'] == '%' ? '%' : (@price_adjustment.currency + ' ')
    amount_display = @adj['unit'] == '%' ? "#{amount_val}%" : number_to_currency(amount_val, unit: unit_val)
  %>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4">
          <h5 class="mb-0 fw-bold">Price Adjustment Overview</h5>
          <p class="text-muted mt-2 mb-0">For <%= @price_adjustment.recipient_company&.name || "Unknown Company" %></p>
        </div>
        <div class="card-body px-4 py-4">
          <div class="row g-4">
            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Status</div>
              <% is_active = @price_adjustment.subscription_active? %>
              <% is_cancelled = @price_adjustment.subscription_cancelled? %>
              <% status_class = is_active ? 'bg-success' : (is_cancelled ? 'bg-danger' : 'bg-secondary') %>
              <% status_text = is_active ? 'Active' : (is_cancelled ? 'Cancelled' : 'Finished') %>
              <span class="badge <%= status_class %> fs-6 px-3 py-2">
                <%= status_text %>
              </span>
            </div>
            
            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Type</div>
              <div class="fs-5 fw-medium">
                <span class="badge bg-info text-dark"><%= type_label %></span>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Billing Cycle</div>
              <div class="fs-5 fw-medium"><%= @cycle.capitalize %></div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Amount</div>
              <div class="fs-5 fw-medium text-primary">
                <%= amount_display %>
                <small class="text-muted fs-6">/ <%= @cycle %></small>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Start Date</div>
              <div class="fs-5 fw-medium">
                <%= @adj['charge_start_date'].present? ? Date.parse(@adj['charge_start_date']).strftime("%b %d, %Y") : "N/A" %>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">End Date</div>
              <div class="fs-5 fw-medium">
                <%= @adj['charge_end_date'].present? ? Date.parse(@adj['charge_end_date']).strftime("%b %d, %Y") : "Indefinite" %>
              </div>
            </div>

            <div class="col-sm-6 col-md-4">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Next Invoice</div>
              <div class="fs-5 fw-medium">
                <% if is_active && @upcoming_invoice_date %>
                  <%= @upcoming_invoice_date.strftime("%b %d, %Y") %>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </div>
            </div>
            
            <div class="col-12">
              <div class="text-muted small fw-semibold text-uppercase mb-1">Description</div>
              <div class="p-3 border rounded-3">
                <%= description %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">Generated Invoices</h5>
        </div>
        <div class="card-body p-0">
          <% if @invoices.empty? %>
            <div class="p-5 text-center text-muted">
              <i class="fa-solid fa-file-invoice fa-3x mb-3 opacity-50"></i>
              <p class="mb-0 fs-5">No sub-invoices generated yet.</p>
            </div>
          <% else %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="ps-4">Invoice #</th>
                    <th>Issue Date</th>
                    <th>Status</th>
                    <th class="text-end">Amount</th>
                    <th class="pe-4 text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% @invoices.each do |invoice| %>
                    <tr>
                      <td class="ps-4 fw-medium">
                        <%= link_to invoice.invoice_number, invoice_path(invoice), class: "text-decoration-none", target: "_blank" %>
                      </td>
                      <td><%= invoice.issue_date&.strftime("%b %d, %Y") %></td>
                      <td>
                        <% status_class = case invoice.status
                           when 'paid' then 'bg-success'
                           when 'draft' then 'bg-secondary'
                           when 'approved' then 'bg-primary'
                           when 'sent' then 'bg-info'
                           when 'overdue' then 'bg-danger'
                           else 'bg-secondary'
                           end %>
                        <span class="badge <%= status_class %>"><%= invoice.status.capitalize %></span>
                      </td>
                      <td class="text-end fw-semibold">
                        <%= number_to_currency(invoice.grand_total, unit: invoice.currency + ' ') %>
                      </td>
                      <td class="pe-4 text-end">
                        <%= link_to "View", invoice_path(invoice), class: "btn btn-sm btn-outline-secondary", target: "_blank" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4 mt-4 mt-lg-0">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header border-bottom-0 pt-4 pb-3 px-4">
          <h5 class="mb-0 fw-bold">Contract Details</h5>
        </div>
        <div class="card-body px-4 py-4">
          <ul class="list-unstyled mb-0">
            <li class="d-flex justify-content-between mb-3">
              <span class="text-muted">Original Invoice #</span>
              <span class="fw-medium">
                <%= link_to @price_adjustment.invoice_number, invoice_path(@price_adjustment) %>
              </span>
            </li>
            <li class="d-flex justify-content-between mb-3">
              <span class="text-muted">Total Cycles Created</span>
              <span class="fw-medium"><%= @price_adjustment.recurring_sub_invoices.count %></span>
            </li>
            <li class="d-flex justify-content-between mb-3">
              <span class="text-muted">Contract Created On</span>
              <span class="fw-medium"><%= @price_adjustment.created_at.strftime("%b %d, %Y") %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
